{
    "name": "@coveritlabs/contracts",
    "version": "0.1.0",
    "description": "CoverIt shared API contracts — Protocol Buffer definitions and generated TypeScript types",
    "type": "commonjs",
    "main": "gen/ts/index.js",
    "types": "gen/ts/index.d.ts",
    "files": [
        "gen/ts",
        "auth",
        "common",
        "buf.yaml",
        "buf.gen.yaml"
    ],
    "scripts": {
        "generate": "buf generate",
        "lint": "buf lint",
        "build": "buf generate",
        "commit": "cz",
        "prepublishOnly": "npm run generate"
    },
    "config": {
        "commitizen": {
            "path": "@commitlint/cz-commitlint"
        }
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4.3",
        "@commitlint/config-conventional": "^20.4.3",
        "@commitlint/cz-commitlint": "^20.4.3",
        "@coveritlabs/git-hooks": "github:CoveritLabs/.github",
        "@bufbuild/buf": "^1.50.0",
        "@bufbuild/protobuf": "^2.5.0",
        "@bufbuild/protoc-gen-es": "^2.5.0",
        "commitizen": "^4.3.1",
        "husky": "^9.1.7"
    }
}
